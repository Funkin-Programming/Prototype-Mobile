<?xml version="1.0" encoding="utf-8"?>
<project>

	<app title="FNF: Prototype" file="Prototype" main="Main" version="0.0.1" company="HaxeFlixel" if="desktop" />
	<app title="FNF: Prototype" file="Prototype" packageName="com.funkin.prototype" package="com.funkin.prototype" main="Main" version="0.0.1" company="HaxeFlixel" if="mobile" />

	<app preloader="flixel.system.FlxPreloader" />
	<set name="SWF_VERSION" value="11.8" />

	<window width="1280" height="720" fps="60" background="#000000" hardware="true" vsync="false" />
	<window if="html5"   resizable="true" />
	<window if="desktop" fullscreen="false" resizable="true" orientation="landscape" />
	<window if="mobile"  fullscreen="true" width="0" height="0" resizable="false"
		orientation="landscape" allow-shaders="true" require-shaders="true" allow-high-dpi="true" />

	<android min-sdk-version="21" target-sdk-version="33" if="android" />
	<architecture name="arm64" if="android" />
	<certificate path="key.keystore" password="prototype" alias="prototype" alias-password="prototype" if="android" unless="debug" />

	<set name="BUILD_DIR" value="export/debug"   if="debug" />
	<set name="BUILD_DIR" value="export/release" unless="debug" />

	<classpath name="source" />

	<assets path="assets" embed="true"  if="mobile" />
	<assets path="assets" embed="false" if="desktop" />

	<haxelib name="lime" />
	<haxelib name="openfl" />
	<haxelib name="flixel" />
	<haxelib name="flixel-addons" />

	<haxedef name="mobile"                if="android" />
	<haxedef name="FLX_NO_MOUSE_ADVANCED" />
	<haxedef name="FLX_NO_MOUSE"          if="mobile" />
	<haxedef name="FLX_NO_KEYBOARD"       if="mobile" />
	<haxedef name="FLX_NO_TOUCH"          if="desktop" />
	<haxedef name="FLX_NO_DEBUG"          if="mobile" />
	<haxedef name="FLX_NO_FOCUS_LOST_SCREEN" />
	<haxedef name="FLX_NO_SOUND_TRAY"    if="mobile" />
	<haxedef name="NAPE_RELEASE_BUILD"    unless="debug" />

	<define name="HXCPP_M64"   if="android" />
	<define name="HXCPP_ARM64" if="android" />

	<section if="android">
		<permission android:name="android.permission.INTERNET" />
		<permission android:name="android.permission.VIBRATE" />
		<permission android:name="android.permission.WAKE_LOCK" />
		<permission android:name="android.permission.RECORD_AUDIO" />
		<permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
		<permission android:name="android.permission.READ_EXTERNAL_STORAGE"  android:maxSdkVersion="32" />
		<permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="28" />
		<permission android:name="android.permission.READ_MEDIA_AUDIO" />
		<permission android:name="android.permission.READ_MEDIA_IMAGES" />
		<permission android:name="android.permission.READ_MEDIA_VIDEO" />

		<queries>
			<intent>
				<action android:name="android.intent.action.VIEW" />
				<data android:scheme="https" />
			</intent>
			<intent>
				<action android:name="android.intent.action.VIEW" />
				<data android:scheme="http" />
			</intent>
			<package android:name="com.android.vending" />
		</queries>
	</section>

	<icon path="art/icon.png" size="16"  />
	<icon path="art/icon.png" size="32"  />
	<icon path="art/icon.png" size="48"  />
	<icon path="art/icon.png" size="64"  />
	<icon path="art/icon.png" size="96"  />
	<icon path="art/icon.png" size="128" />
	<icon path="art/icon.png" size="192" />
	<icon path="art/icon.png" size="512" />

</project>
